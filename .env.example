# Copy this file to .env and fill in your values before starting Docker.
#
#   cp .env.example .env      (Linux / macOS)
#   copy .env.example .env    (Windows)

# Admin password for the upload / admin interface.
# Set a strong, unique password. No default is provided — the server will
# prompt you to choose one on first run if this is not set.
# ADMIN_PASSWORD=
