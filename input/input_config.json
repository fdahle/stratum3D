{
  "shapes/georef_sat.geojson": {
    "metadata": {
      "hasThumbnails": true,
      "thumbnailTemplate": "https://data.pgc.umn.edu/aerial/usgs/tma/photos/thumb/CA{tma_number}/CA{tma_number}32V/{image_id}_thumbnail.jpg",
      "headerAttribute": "image_id",
      "hasDownloadLinks": true,
      "downloadLinkTemplate": "https://data.pgc.umn.edu/aerial/usgs/tma/photos/high/CA{tma_number}/CA{tma_number}32V/{image_id}.tif"
    },
    "attributes": {
      "attributesFile": "attributes/images.csv",
      "attributesKey": "image_id",
      "attributesDelimiter": ";",
      "ownKey": "image_id"
    }
  },
  "shapes/tma_lines.geojson": {
    "metadata": {
      "headerAttribute": "tma_num",
      "has3DModels": false,
      "hasPointClouds": false
    },
    "attributes": {
      "attributesFile": "attributes/tma_lines.csv",
      "attributesKey": "tma_num",
      "attributesDelimiter": ";",
      "ownKey": "tma_num"
    }
  },
  "shapes/glaciers.geojson": {
    "metadata": {
      "headerAttribute": "glac_name",
      "has3DModels": true,
      "3DModels": [
        {
          "linkTemplate": "{glac_name}.obj"
        }
      ],
      "hasPointClouds": true,
      "pointclouds": []
    }
  }
}
