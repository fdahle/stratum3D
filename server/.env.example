# Server configuration — copy this to .env and adjust as needed.
# .env is never committed to git.

PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Comma-separated list of allowed CORS origins (your frontend URL(s))
CORS_ORIGINS=http://localhost:8080

# Path where uploaded data and config are stored (relative to server/)
DATA_PATH=./data

LOG_LEVEL=info

# Set to true to enable strict HTTP security headers (recommended in production)
ENABLE_HELMET=true
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Per-file upload size limit in MB
UPLOAD_LIMIT_MB=500

# Set to false to remove all /admin/* routes entirely.
# Do this once your data is loaded and the site is locked down for public use.
# The admin panel will not exist at the network level — no button, no routes, no attack surface.
ADMIN_ENABLED=true
