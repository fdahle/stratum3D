# Example .env file for server configuration
# Copy this file to .env and adjust values as needed

# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# CORS Configuration (comma-separated origins)
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:4173

# Paths
DATA_PATH=./data

# Logging
LOG_LEVEL=info

# Security (production only)
ENABLE_HELMET=false
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# Admin panel password (required to access /admin and save config changes)
ADMIN_PASSWORD=changeme
